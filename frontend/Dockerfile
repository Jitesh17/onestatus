# Frontend image: build the static bundle, serve it with nginx, and proxy /api
# to the backend container so the browser talks to one origin (no CORS in deploy).
FROM node:20-alpine AS build
WORKDIR /src
COPY package.json package-lock.json ./
# The lock file is generated by npm 11; npm 10 (bundled with node 20) rejects
# its nested-optional-dependency entries, so match the generator's major.
RUN npm install -g npm@11 && npm ci
COPY . .
RUN npm run build

FROM nginx:alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /src/dist /usr/share/nginx/html
EXPOSE 80
