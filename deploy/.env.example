# Copy to .env in this folder before starting the stack.

# ---- First admin account (set this first) ----
# Created once, when the user table is empty (first boot). Log in with it,
# then create the team's accounts from the Admin tab. Locked out? Run:
#   docker compose exec backend python -m app.create_admin
ADMIN_USER=admin
ADMIN_PASSWORD=

# 1 also seeds demo login accounts (admin/admin, alex/demo, sam/demo, ...).
# For demos on throwaway data only; never enable on a real deployment.
SEED_DEMO_USERS=0

# ---- Optional extra gate ----
# Basic-auth prompt at nginx in front of the app's own login. Useful as a
# second layer on a shared network; leave empty to rely on app login alone.
APP_USER=onestatus
APP_PASSWORD=

# ---- LLM ----
# ollama (local, default) | openai (any OpenAI-compatible API) | anthropic.
# All of these can also be changed live in the app's settings panel (gear icon).
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
#LLM_API_KEY=
#LLM_BASE_URL=

# ---- Speech to text (always local) ----
# tiny | base | small | medium | large-v2 | large-v3
WHISPER_MODEL=medium

# ---- Boot-time ----
# 1 seeds demo data into an empty database on first start; 0 for a clean start.
SEED_ON_START=1
# Postgres instead of SQLite (start with: docker compose --profile postgres up -d):
#DATABASE_URL=postgresql+psycopg2://onestatus:onestatus@db:5432/onestatus
#POSTGRES_USER=onestatus
#POSTGRES_PASSWORD=onestatus
#POSTGRES_DB=onestatus

# ---- Host port ----
#FRONTEND_PORT=8080
