# Copy to .env and adjust. Every value below is the default; the file is optional.
# All of these can also be changed live in the app's settings panel (gear icon),
# except the boot-time ones marked as such.

# ---- Access ----
# Set a password to require a login for everything (the app, the API, the
# settings panel). Required for any deployment others can reach; leave empty
# only on your own machine.
APP_USER=onestatus
APP_PASSWORD=
# Swagger/openapi endpoints. Off in compose; set 1 only while debugging.
#API_DOCS=0

# ---- LLM ----
# ollama (local, default) | openai (any OpenAI-compatible API) | anthropic
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
# In compose the backend reaches the bundled Ollama at http://ollama:11434
# (set by docker-compose.yml); on a bare machine the default is localhost.
#OLLAMA_URL=http://localhost:11434

# Cloud mode examples (uncomment, set the key, switch LLM_PROVIDER):
#LLM_PROVIDER=openai
#LLM_MODEL=gpt-4o-mini
#LLM_API_KEY=sk-...
# Optional OpenAI-compatible server (vLLM, LiteLLM, Ollama's own /v1):
#LLM_BASE_URL=http://gpu-box:8000

#LLM_PROVIDER=anthropic
#LLM_MODEL=claude-haiku-4-5-20251001
#LLM_API_KEY=sk-ant-...

LLM_TEMPERATURE=0
LLM_TIMEOUT=120

# ---- Speech to text (always local) ----
# tiny | base | small | medium | large-v2 | large-v3
WHISPER_MODEL=medium
# cpu | cuda (cuda needs the CUDA libraries inside the image; CPU is the default)
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8
WHISPER_BEAM=5
WHISPER_VAD=1

# ---- Boot-time only (restart to change) ----
# Default in compose is SQLite on the app_data volume. Postgres alternative:
#DATABASE_URL=postgresql+psycopg2://onestatus:onestatus@db:5432/onestatus
SEED_ON_START=1
#CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
#MAX_AUDIO_BYTES=26214400
#MAX_TEXT_LEN=10000

# ---- Host port mappings (compose only) ----
#FRONTEND_PORT=8080
#POSTGRES_PORT=5432

# ---- Postgres profile (docker compose --profile postgres) ----
#POSTGRES_USER=onestatus
#POSTGRES_PASSWORD=onestatus
#POSTGRES_DB=onestatus
